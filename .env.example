# Core Environment Variables (Local Development)

# --- apps/web ---
# Supabase API URL (Local default)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Supabase Local Anon Key (Get from 'pnpm --filter @repo/supabase status')
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-local-anon-key
# Redirect URL for Auth (Local)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- packages/db ---
# Local Database Connection (Local default)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
